
CLAUDENOMICS_AUTH_URL=http://localhost:3000/cli-auth

# Log level: debug | info | warn | error. Equivalent to `--verbose` for `debug`.
CLAUDENOMICS_LOG=info

# Passed through to child `claude` / `codex` processes. Set one if you use
# API-key auth with the wrapped CLIs; otherwise leave unset and sign in via
# the child's own flow (`claude login`, etc.).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

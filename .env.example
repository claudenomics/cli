# CLI

# Auth backend URL. https, or http on loopback.
CLAUDENOMICS_AUTH_URL=

# JWKS and issuer for session JWT verification.
CLAUDENOMICS_JWKS_URL=
CLAUDENOMICS_JWT_ISSUER=
# CLAUDENOMICS_JWT_AUDIENCE=

# Enclave URL for attested routing. Unset routes directly to the vendor.
# CLAUDENOMICS_ENCLAVE_URL=

# debug | info | warn | error
# CLAUDENOMICS_LOG=info

# Forwarded to the child claude/codex process.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=


# Enclave

# production | simulator
DSTACK_MODE=

# 32+ bytes: hex (64+ chars), base64 (44+), or base64url (43+).
# ENCLAVE_SEED=

# anthropic | openai
UPSTREAM=anthropic

CLAUDENOMICS_JWKS_URL=
CLAUDENOMICS_JWT_ISSUER=
# CLAUDENOMICS_JWT_AUDIENCE=
# CLAUDENOMICS_JWT_WALLET_CLAIM=wallet

# PORT=8787
# MAX_REQUEST_BYTES=10485760
# MAX_RESPONSE_BYTES=67108864
# RATE_LIMIT_PER_MIN=120
